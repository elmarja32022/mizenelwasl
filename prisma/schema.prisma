// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String
  password         String
  phone            String?
  image            String?  // صورة الملف الشخصي
  country          String?
  city             String?
  neighborhood     String?
  timeBalance      Int      @default(300) // 5 ساعات = 300 دقيقة
  integrityScore   Int      @default(100)
  trustLevel       String   @default("موثوق")
  rating           Float    @default(0)
  totalExchanges   Int      @default(0)
  totalVotes       Int      @default(0) // عدد التصويتات المستلمة
  covenantSigned   Boolean  @default(false) // توقيع ميثاق الوصل والعهد
  covenantSignedAt DateTime? // تاريخ توقيع الميثاق
  isAdmin          Boolean  @default(false) // صلاحيات الخليفة المختار
  isSuspended      Boolean  @default(false) // تعليق الحساب
  emailVerified    Boolean  @default(false) // التحقق من البريد
  verificationToken String? @unique // رمز التحقق
  verificationExpires DateTime? // تاريخ انتهاء رمز التحقق
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  services             Service[]
  products             Product[]
  exchangesAsInitiator Exchange[] @relation("InitiatorExchanges")
  exchangesAsProvider  Exchange[] @relation("ProviderExchanges")
  posts                CommunityPost[]
  comments             Comment[]
  postVotes            PostVote[]
  notifications        Notification[]
  
  // تصويت النزاهة
  votesGiven          IntegrityVote[] @relation("VoterVotes") // التصويتات المعطاة
  votesReceived       IntegrityVote[] @relation("TargetVotes") // التصويتات المستلمة
  
  // الرسائل المباشرة
  sentMessages        Message[]      @relation("SentMessages")
  receivedMessages    Message[]      @relation("ReceivedMessages")
  conversationsAsUser1 Conversation[] @relation("User1Conversations")
  conversationsAsUser2 Conversation[] @relation("User2Conversations")
  
  // التبرعات
  donations           Donation[]     // تبرعات المستخدم
  
  // المشاريع
  projects            Project[]      // مشاريع المستخدم
  projectSupports     ProjectSupport[] // دعم المشاريع
  projectComments     ProjectComment[] // تعليقات المشاريع
}

model Service {
  id          String   @id @default(cuid())
  title       String
  titleAr     String
  description String
  type        String // OFFER | REQUEST
  category    String
  duration    Int // بالدقائق
  status      String   @default("ACTIVE") // ACTIVE | PENDING | COMPLETED
  images      String?
  videoUrl    String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchanges   Exchange[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  nameAr      String
  description String?
  quantity    Float
  unit        String
  quality     String   @default("جيد جداً") // ممتاز | جيد جداً | جيد | مقبول
  type        String // OFFER | REQUEST
  category    String
  images      String?
  videoUrl    String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchanges   Exchange[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Exchange {
  id          String   @id @default(cuid())
  type        String // SERVICE | PRODUCT
  status      String   @default("PENDING") // PENDING | ACCEPTED | COMPLETED | REJECTED
  initiatorId String
  providerId  String
  serviceId   String?
  productId   String?
  timeAmount  Int // دقائق
  notes       String?
  rating      Int? // 1-5
  review      String?
  initiator   User     @relation("InitiatorExchanges", fields: [initiatorId], references: [id])
  provider    User     @relation("ProviderExchanges", fields: [providerId], references: [id])
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  integrityVotes IntegrityVote[] // تصويتات النزاهة المرتبطة
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CommunityPost {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String // POST | DISCUSSION | SUGGESTION | SUCCESS_STORY
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  Comment[]
  votes     PostVote[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id        String        @id @default(cuid())
  content   String
  postId    String
  userId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
}

// تصويت النزاهة
model IntegrityVote {
  id           String   @id @default(cuid())
  voterId      String   // المصوّت
  targetId     String   // المستهدف بالتصويت
  exchangeId   String?  // التبادل المرتبط (اختياري)
  
  // تصنيفات التصويت (1-5 نجوم لكل تصنيف)
  honestyScore     Int @default(5) // الصدق والأمانة
  commitmentScore  Int @default(5) // الالتزام بالمواعيد
  qualityScore     Int @default(5) // جودة العمل/الخدمة
  cooperationScore Int @default(5) // روح التعاون
  
  // التقييم العام والملاحظات
  overallScore Int     @default(5) // التقييم العام (1-5)
  comment      String? // تعليق (اختياري)
  isAnonymous  Boolean @default(false) // تصويت مجهول
  
  // حالة التصويت
  status       String  @default("ACTIVE") // ACTIVE | DISPUTED | REMOVED
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // العلاقات
  voter        User     @relation("VoterVotes", fields: [voterId], references: [id], onDelete: Cascade)
  target       User     @relation("TargetVotes", fields: [targetId], references: [id], onDelete: Cascade)
  exchange     Exchange? @relation(fields: [exchangeId], references: [id], onDelete: SetNull)
  
  @@unique([voterId, targetId]) // تصويت واحد لكل مستخدم لكل هدف
}

model PostVote {
  id         String        @id @default(cuid())
  type       String // POSITIVE | NEGATIVE
  postId     String
  userId     String
  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
}

model Notification {
  id           String   @id @default(cuid())
  type         String // EXCHANGE_REQUEST | EXCHANGE_RESPONSE | RATING | SYSTEM | ANNOUNCEMENT | WARNING
  title        String
  message      String
  read         Boolean  @default(false)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetScope  String?  @default("ALL") // ALL | COUNTRY | CITY | NEIGHBORHOOD | USER
  targetValue  String?  // قيمة الهدف (اسم الدولة/المدينة/الحي/معرف المستخدم)
  createdAt    DateTime @default(now())
}

// منشورات الخليفة الرسمية
model KhalifaAnnouncement {
  id          String   @id @default(cuid())
  title       String
  content     String
  type        String   @default("ANNOUNCEMENT") // ANNOUNCEMENT | WARNING | UPDATE | EVENT
  priority    String   @default("NORMAL") // HIGH | NORMAL | LOW
  isPinned    Boolean  @default(true) // مثبت في الأعلى
  targetScope String   @default("ALL") // ALL | COUNTRY | CITY | NEIGHBORHOOD
  targetValue String?  // قيمة الهدف
  expiresAt   DateTime? // تاريخ انتهاء الظهور
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  category  String   @default("GENERAL") // GENERAL | SUPPORT | COMPLAINT | SUGGESTION
  status    String   @default("PENDING") // PENDING | READ | RESPONDED | RESOLVED
  createdAt DateTime @default(now())
}

model Category {
  id        String   @id @default(cuid())
  name      String
  nameAr    String
  type      String // SERVICE | PRODUCT
  icon      String?
  createdAt DateTime @default(now())
}

// المحادثات بين الخلفاء
model Conversation {
  id          String   @id @default(cuid())
  user1Id     String
  user2Id     String
  lastMessage String?
  lastMessageAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user1       User      @relation("User1Conversations", fields: [user1Id], references: [id], onDelete: Cascade)
  user2       User      @relation("User2Conversations", fields: [user2Id], references: [id], onDelete: Cascade)
  messages    Message[]
  
  @@unique([user1Id, user2Id])
}

// الرسائل المباشرة
model Message {
  id             String   @id @default(cuid())
  content        String
  read           Boolean  @default(false)
  senderId       String
  receiverId     String
  conversationId String
  createdAt      DateTime @default(now())
  
  sender         User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver       User          @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// إعدادات البريد الإلكتروني
model EmailSettings {
  id            String   @id @default(cuid())
  smtpHost      String   // خادم SMTP
  smtpPort      Int      @default(587) // منفذ SMTP
  smtpUser      String   // اسم المستخدم
  smtpPassword  String   // كلمة المرور
  fromEmail     String   // البريد المرسل
  fromName      String   @default("ميزان الوصل") // اسم المرسل
  useTLS        Boolean  @default(true) // استخدام TLS
  emailVerified Boolean  @default(false) // تفعيل التحقق من البريد
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// أكاديمية مذهب ميزان الوصل
model AcademyCourse {
  id          String   @id @default(cuid())
  title       String   // عنوان الدورة
  description String   // وصف الدورة
  icon        String?  // أيقونة الدورة
  color       String   @default("emerald") // لون الدورة
  order       Int      @default(0) // ترتيب العرض
  isPublished Boolean  @default(false) // منشورة أم لا
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  lessons     AcademyLesson[] // الدروس
}

model AcademyLesson {
  id          String   @id @default(cuid())
  courseId    String   // معرف الدورة
  title       String   // عنوان الدرس
  content     String   // محتوى الدرس
  videoUrl    String?  // رابط الفيديو
  imageUrl    String?  // صورة الدرس
  order       Int      @default(0) // ترتيب العرض
  duration    Int      @default(0) // مدة الدرس بالدقائق
  isPublished Boolean  @default(false) // منشور أم لا
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  course      AcademyCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress    UserLessonProgress[] // تقدم المستخدمين
}

// تقدم المستخدم في الدروس
model UserLessonProgress {
  id         String   @id @default(cuid())
  userId     String
  lessonId   String
  completed  Boolean  @default(false)
  completedAt DateTime?
  createdAt  DateTime @default(now())
  
  lesson     AcademyLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@unique([userId, lessonId]) // كل مستخدم له سجل واحد لكل درس
}

// تبرعات المجتمع
model Donation {
  id          String   @id @default(cuid())
  donorId     String   // المتبرع
  type        String   // TIME | MONEY | GOODS | SKILL
  title       String   // عنوان التبرع
  description String?  // وصف التبرع
  amount      Float    @default(0) // القيمة (ساعات للمهارات/الوقت، مال للتبرعات المالية)
  unit        String?  // الوحدة (ساعة، ريال، كيلو، إلخ)
  category    String?  // فئة التبرع (تعليم، صحة، غذاء، إلخ)
  status      String   @default("PENDING") // PENDING | APPROVED | COMPLETED | CANCELLED
  priority    String   @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  isAnonymous Boolean  @default(false) // تبرع مجهول
  beneficiary String?  // المستفيد (اسم أو وصف)
  notes       String?  // ملاحظات إضافية
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime? // تاريخ الإنجاز
  
  // العلاقات
  donor       User     @relation(fields: [donorId], references: [id], onDelete: Cascade)
  
  @@index([type])
  @@index([status])
  @@index([category])
}

// مشاريع الابتكار ودعم المجتمع
model Project {
  id              String   @id @default(cuid())
  creatorId       String   // صاحب المشروع
  
  // معلومات المشروع
  title           String   // عنوان المشروع
  description     String   // وصف المشروع
  category        String   // فئة المشروع (تقنية، تعليمية، اجتماعية، بيئية، صحية، أخرى)
  stage           String   @default("IDEA") // IDEA | PLANNING | DEVELOPMENT | TESTING | LAUNCHED
  
  // الاحتياجات
  needsTime       Boolean  @default(false) // يحتاج دعم وقت
  needsMoney      Boolean  @default(false) // يحتاج دعم مالي
  needsSkills     Boolean  @default(false) // يحتاج مهارات
  needsMaterials  Boolean  @default(false) // يحتاج مواد
  
  // الأهداف
  targetAmount    Float    @default(0) // المبلغ المستهدف
  targetTime      Int      @default(0) // الوقت المستهدف (ساعات)
  targetSupporters Int     @default(0) // عدد الداعمين المستهدف
  
  // التقدم
  currentAmount   Float    @default(0) // المبلغ الحالي
  currentTime     Int      @default(0) // الوقت الحالي
  currentSupporters Int    @default(0) // عدد الداعمين الحالي
  
  // الحالة
  status          String   @default("DRAFT") // DRAFT | PENDING | ACTIVE | FUNDED | COMPLETED | CANCELLED
  isPublic        Boolean  @default(true) // مشروع عام
  allowComments   Boolean  @default(true) // السماح بالتعليقات
  
  // صور وفيديو
  images          String?  // روابط الصور (JSON)
  videoUrl        String?  // رابط فيديو عرض المشروع
  
  // التواريخ
  startDate       DateTime? // تاريخ البدء
  endDate         DateTime? // تاريخ الانتهاء المتوقع
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // العلاقات
  creator         User           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  supports        ProjectSupport[]
  comments        ProjectComment[]
  
  @@index([category])
  @@index([status])
  @@index([stage])
}

// دعم المشاريع
model ProjectSupport {
  id          String   @id @default(cuid())
  projectId   String
  supporterId String
  
  // نوع الدعم
  type        String   // TIME | MONEY | SKILL | MATERIALS
  
  // تفاصيل الدعم
  amount      Float    @default(0) // المبلغ (للدعم المالي)
  hours       Int      @default(0) // الساعات (للدعم بالوقت)
  description String?  // وصف الدعم (للمهارات والمواد)
  
  // الحالة
  status      String   @default("PENDING") // PENDING | CONFIRMED | COMPLETED
  
  createdAt   DateTime @default(now())
  
  // العلاقات
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supporter   User     @relation(fields: [supporterId], references: [id], onDelete: Cascade)
  
  @@unique([projectId, supporterId, type]) // دعم واحد من كل نوع لكل مشروع
}

// تعليقات المشاريع
model ProjectComment {
  id          String   @id @default(cuid())
  projectId   String
  userId      String
  content     String
  
  createdAt   DateTime @default(now())
  
  // العلاقات
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// مكتبة ميزان الوصل
model Book {
  id              String   @id @default(cuid())
  
  // معلومات الكتاب
  title           String   // عنوان الكتاب
  author          String?  // المؤلف
  description     String?  // وصف الكتاب
  coverImage      String?  // صورة الغلاف
  
  // التصنيف
  category        String   // فئة الكتاب (فقه، تفسير، سيرة، أخلاق، تنمية بشرية، أخرى)
  
  // السعر والتوفر
  isFree          Boolean  @default(true)  // مجاني أم بمقابل
  price           Float    @default(0)     // السعر (للكتب غير المجانية)
  currency        String   @default("ريال") // العملة
  
  // الملف
  fileUrl         String?  // رابط ملف الكتاب (PDF)
  externalUrl     String?  // رابط خارجي للكتاب
  
  // معلومات إضافية
  pages           Int?     // عدد الصفحات
  language        String   @default("العربية") // اللغة
  publisher       String?  // الناشر
  publishYear     Int?     // سنة النشر
  isbn            String?  // رقم ISBN
  
  // التقييم والإحصائيات
  rating          Float    @default(0) // متوسط التقييم
  totalRatings    Int      @default(0) // عدد التقييمات
  downloadCount   Int      @default(0) // عدد التحميلات
  viewCount       Int      @default(0) // عدد المشاهدات
  
  // الحالة
  status          String   @default("PUBLISHED") // DRAFT | PUBLISHED | ARCHIVED
  featured        Boolean  @default(false) // كتاب مميز
  order           Int      @default(0) // ترتيب العرض
  
  // التواريخ
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // العلاقات
  ratings         BookRating[]
  purchases       BookPurchase[]
  
  @@index([category])
  @@index([isFree])
  @@index([featured])
}

// تقييمات الكتب
model BookRating {
  id          String   @id @default(cuid())
  bookId      String
  userId      String
  rating      Int      // 1-5
  review      String?
  
  createdAt   DateTime @default(now())
  
  // العلاقات
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  
  @@unique([bookId, userId]) // تقييم واحد لكل مستخدم لكل كتاب
}

// مشتريات الكتب
model BookPurchase {
  id          String   @id @default(cuid())
  bookId      String
  userId      String
  
  // تفاصيل الشراء
  pricePaid   Float    // السعر المدفوع
  currency    String   @default("ريال")
  
  // الحالة
  status      String   @default("COMPLETED") // PENDING | COMPLETED | REFUNDED
  
  purchasedAt DateTime @default(now())
  
  // العلاقات
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  
  @@unique([bookId, userId]) // شراء واحد لكل مستخدم لكل كتاب
}
