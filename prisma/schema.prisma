// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  password       String
  phone          String?
  country        String?
  city           String?
  neighborhood   String?
  timeBalance    Int      @default(300) // 5 ساعات = 300 دقيقة
  integrityScore Int      @default(100)
  trustLevel     String   @default("موثوق")
  rating         Float    @default(0)
  totalExchanges Int      @default(0)
  covenantSigned Boolean  @default(false) // توقيع ميثاق الوصل والعهد
  covenantSignedAt DateTime? // تاريخ توقيع الميثاق
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  services             Service[]
  products             Product[]
  exchangesAsInitiator Exchange[] @relation("InitiatorExchanges")
  exchangesAsProvider  Exchange[] @relation("ProviderExchanges")
  posts                CommunityPost[]
  comments             Comment[]
  userVotes            UserVote[]
  postVotes            PostVote[]
  notifications        Notification[]
}

model Service {
  id          String   @id @default(cuid())
  title       String
  titleAr     String
  description String
  type        String // OFFER | REQUEST
  category    String
  duration    Int // بالدقائق
  status      String   @default("ACTIVE") // ACTIVE | PENDING | COMPLETED
  images      String?
  videoUrl    String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchanges   Exchange[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  nameAr      String
  description String?
  quantity    Float
  unit        String
  quality     String   @default("جيد جداً") // ممتاز | جيد جداً | جيد | مقبول
  type        String // OFFER | REQUEST
  category    String
  images      String?
  videoUrl    String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchanges   Exchange[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Exchange {
  id          String   @id @default(cuid())
  type        String // SERVICE | PRODUCT
  status      String   @default("PENDING") // PENDING | ACCEPTED | COMPLETED | REJECTED
  initiatorId String
  providerId  String
  serviceId   String?
  productId   String?
  timeAmount  Int // دقائق
  notes       String?
  rating      Int? // 1-5
  review      String?
  initiator   User     @relation("InitiatorExchanges", fields: [initiatorId], references: [id])
  provider    User     @relation("ProviderExchanges", fields: [providerId], references: [id])
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CommunityPost {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String // POST | DISCUSSION | SUGGESTION | SUCCESS_STORY
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  Comment[]
  votes     PostVote[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id        String        @id @default(cuid())
  content   String
  postId    String
  userId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
}

model UserVote {
  id         String   @id @default(cuid())
  type       String // POSITIVE | NEGATIVE
  targetId   String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model PostVote {
  id         String        @id @default(cuid())
  type       String // POSITIVE | NEGATIVE
  postId     String
  userId     String
  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  type      String // EXCHANGE_REQUEST | EXCHANGE_RESPONSE | RATING | SYSTEM
  title     String
  message   String
  read      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  category  String   @default("GENERAL") // GENERAL | SUPPORT | COMPLAINT | SUGGESTION
  status    String   @default("PENDING") // PENDING | READ | RESPONDED | RESOLVED
  createdAt DateTime @default(now())
}

model Category {
  id        String   @id @default(cuid())
  name      String
  nameAr    String
  type      String // SERVICE | PRODUCT
  icon      String?
  createdAt DateTime @default(now())
}
